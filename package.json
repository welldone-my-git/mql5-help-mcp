{
  "name": "knowledge-mcp",
  "version": "2.0.0",
  "description": "General-purpose knowledge base MCP server — domain plugins, semantic search, PDF/HTML/Markdown ingestion",
  "type": "module",
  "author": "welldone-my-git",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/welldone-my-git/kb-mcp-esp4-mql5.git"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "keywords": [
    "mcp",
    "knowledge-base",
    "semantic-search",
    "ollama",
    "mql5",
    "documentation",
    "trading",
    "metatrader",
    "enterprise"
  ],
  "files": [
    "build/",
    "MQL5_HELP/",
    "MQL5_Algo_Book/",
    "Neural_Networks_Book/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "knowledge-mcp": "./build/index.js",
    "mql5-help-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:unit": "npm run build && node --test test/unit.test.mjs",
    "test:smoke": "npm run build && node --test test/mcp-smoke.test.mjs",
    "dev": "node build/index.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.7.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
